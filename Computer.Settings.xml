<!--
    BELANGRIJK: Pas de macaddress-waarden aan naar uw eigen netwerkkaarten.
    Controleer uw MAC-adressen via PowerShell:
        Get-NetAdapter | Select-Object Name, MacAddress
    De hostname dc01besv is al ingevuld met uw initialen (besv).
-->
<Settings>
<name>dc01besv</name>
<networksettings>
<networkadapter>
  <name>lan</name>
  <macaddress>00-0C-29-C6-71-3D</macaddress>
  <dhcpenabled>false</dhcpenabled>
  <ip>10.1.10.201</ip>
  <prefixlength>24</prefixlength>
  <gateway>10.1.10.201</gateway>
  <dns>10.1.10.201</dns>
  <subnet>255.255.255.0</subnet>
</networkadapter>
<networkadapter>
  <name>wan</name>
  <macaddress>00-0C-29-C6-71-33</macaddress>
  <dhcpenabled>true</dhcpenabled>
  <ip></ip>
  <prefixlength>24</prefixlength>
  <gateway></gateway>
  <dns></dns>
  <subnet></subnet>
</networkadapter>
<networkadapter>
  <name>lan2</name>
  <macaddress>00-0C-29-C6-71-2F</macaddress>
  <dhcpenabled>false</dhcpenabled>
  <ip>10.1.10.202</ip>
  <prefixlength>24</prefixlength>
  <gateway>10.1.10.201</gateway>
  <dns>10.1.10.201</dns>
  <subnet>255.255.255.0</subnet>
</networkadapter>
</networksettings>
</Settings>
